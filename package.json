{
  "name": "dcs-sports-backend",
  "version": "0.1.0",
  "private": true,
  "description": "DCS Sports — CW16 lane: API gateway, BullMQ queue, agents, revenue (DARK), alerts, M-S1 E2E harness",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/gateway/server.js",
